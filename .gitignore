# local Claude Code config
.claude/
.vscode/

# python
__pycache__/
*.pyc
.venv/
venv/

# data/: local-only working area. The raw mirror DATA is a GitHub Release asset (gitignored); only
# its committed anchors — the checksum ledger + provenance manifest — live in git. Everything else
# under data/ (clusters/, opinions/, the .tar.gz archive, processed/, legacy caches) stays ignored.
data/*
!data/raw/
data/raw/*
!data/raw/extract_manifest.json
!data/raw/CHECKSUMS.sha256

# database artifacts (regenerable; distributed via GitHub Release)
*.sqlite
*.sqlite-journal
*.sqlite.gz
SHA256SUMS

# secrets — never commit the CourtListener token
*.token
.env

# pytest
.pytest_cache/

# python packaging build artifacts
*.egg-info/
build/
dist/

# coverage
.coverage
.coverage.*
htmlcov/

# macOS (keep out even inside committed dirs — last match wins)
.DS_Store
